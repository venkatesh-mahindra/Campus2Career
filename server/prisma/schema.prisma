// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  sapId            String   @unique
  name             String
  password         String
  branch           String
  currentYear      Int      @default(1)
  onboardingStep   Int      @default(0) // 0: select year, 1: profile, 2: goals, 3: completed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  digitalTwin      DigitalTwin?
  assessments      Assessment[]
  skills           Skill[]
  roadmap          Roadmap?
}

model DigitalTwin {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  leetcodeUsername String?
  githubUrl        String?
  cgpa             Float?   @default(0.0)
  interests        String?  // JSON stringified array
  goals            String?  // JSON stringified array
  strengths        String?  // JSON stringified array
  weaknesses       String?  // JSON stringified array
  updatedAt        DateTime @updatedAt
}

model Skill {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  name             String
  level            Int      @default(1) // 1-5
  category         String   // Technical, Soft, Language
  createdAt        DateTime @default(now())
}

model Assessment {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  type             String   // SWOC, Psychometric, Personality
  results          String   // JSON stringified results
  createdAt        DateTime @default(now())
}

model Roadmap {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  milestones       String   // JSON stringified adaptive roadmap
  updatedAt        DateTime @updatedAt
}
